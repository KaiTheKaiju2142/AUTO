-- ================= PUNCHING BAG DAMAGE =================
local ReplicatedStorage = game:GetService("ReplicatedStorage")
local DamageRemote = ReplicatedStorage:WaitForChild("DamageRemote")
local Players = game:GetService("Players")
local player = Players.LocalPlayer
local character = player.Character or player.CharacterAdded:Wait()
local humanoidRoot = character:WaitForChild("HumanoidRootPart")

local function getPunchingBag()
    for _, obj in pairs(workspace:GetDescendants()) do
        if obj:IsA("Model") and obj.Name == "PunchingBag" then
            local bagPart = obj:FindFirstChild("Bag", true)
            local humanoid = obj:FindFirstChildOfClass("Humanoid")
            if bagPart and humanoid then
                if (humanoidRoot.Position - bagPart.Position).Magnitude <= 8 then
                    return humanoid
                end
            end
        end
        if obj:IsA("BasePart") and obj.Name == "Bag" then
            local model = obj:FindFirstAncestor("PunchingBag")
            if model then
                local humanoid = model:FindFirstChildOfClass("Humanoid")
                if humanoid then
                    if (humanoidRoot.Position - obj.Position).Magnitude <= 8 then
                        return humanoid
                    end
                end
            end
        end
    end
    return nil
end

task.spawn(function()
    while true do
        task.wait(0)
        if PunchingBagFarm then
            local targetHumanoid = getPunchingBag()
            if targetHumanoid then
                DamageRemote:FireServer(targetHumanoid, 24328, false)
            end
        end
    end
end)
